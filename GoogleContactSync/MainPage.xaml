<Page
    x:Class="GoogleContactSync.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,16,20,32">

            <!-- HEADER -->
            <TextBlock Text="Google Contact Sync"
                       FontSize="24" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Sync Google Contacts via People API"
                       FontSize="13"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       Margin="0,0,0,24"/>

            <!-- LOGIN PANEL -->
            <StackPanel x:Name="PanelLogin">
                <TextBlock Text="Google API credentials"
                           FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <Button x:Name="BtnLoadJson"
                        Content="&#xE8DA;  Load client_secret.json"
                        HorizontalAlignment="Stretch"
                        Height="44" FontSize="13"
                        Click="BtnLoadJson_Click"
                        Margin="0,0,0,16"/>

                <TextBlock Text="Client ID" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtClientId"
                         PlaceholderText="...apps.googleusercontent.com"
                         FontSize="14" Margin="0,0,0,12"/>

                <TextBlock Text="Client Secret" FontSize="12" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtClientSecret"
                             PlaceholderText="GOCSPX-..."
                             FontSize="14" Margin="0,0,0,20"/>

                <Button x:Name="BtnLogin"
                        Content="Sign in with Google"
                        HorizontalAlignment="Stretch"
                        Height="52" FontSize="15"
                        Click="BtnLogin_Click"/>
            </StackPanel>

            <!-- CODE PANEL -->
            <StackPanel x:Name="PanelCode" Visibility="Collapsed"
                        Margin="0,20,0,0">
                <TextBlock Text="Open this URL in a browser on another device:"
                           TextWrapping="Wrap" FontSize="13"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtVerificationUrl"
                           FontSize="13" Foreground="#0078D7"
                           TextWrapping="Wrap" Margin="0,0,0,16"/>
                <TextBlock Text="Then enter this code:"
                           FontSize="13" Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtUserCode"
                           FontSize="36" FontWeight="Bold"
                           Foreground="Orange"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <ProgressBar IsIndeterminate="True"
                             Height="4" Margin="0,0,0,8"/>
                <TextBlock Text="Waiting for authorization..."
                           FontSize="13"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- LOGGED IN PANEL -->
            <StackPanel x:Name="PanelLoggedIn" Visibility="Collapsed"
                        Margin="0,20,0,0">
                <TextBlock x:Name="TxtAccountInfo"
                           FontSize="13" Foreground="#2E7D32"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16"/>

                <Button x:Name="BtnGoogleToPhone"
                        Content="&#xE896;  Google → Phone"
                        HorizontalAlignment="Stretch"
                        Height="52" FontSize="15"
                        Click="BtnGoogleToPhone_Click"
                        Margin="0,0,0,8"/>

                <Button x:Name="BtnPhoneToGoogle"
                        Content="&#xE898;  Phone → Google"
                        HorizontalAlignment="Stretch"
                        Height="52" FontSize="15"
                        Click="BtnPhoneToGoogle_Click"
                        Margin="0,0,0,8"/>

                <Button x:Name="BtnSync"
                        Content="&#xE895;  Bidirectional Sync"
                        HorizontalAlignment="Stretch"
                        Height="52" FontSize="15"
                        Click="BtnSync_Click"
                        Margin="0,0,0,16"/>

                <Button x:Name="BtnSignOut"
                        Content="Sign out"
                        HorizontalAlignment="Stretch"
                        Height="44" FontSize="13"
                        Click="BtnSignOut_Click"/>

                <!-- BG SYNC STATUS -->
                <Border Margin="0,16,0,0"
                        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        Padding="12,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Auto sync: " FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtBgStatus"
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="Not registered"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtLastBgSync"
                                   FontSize="11"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,2,0,4"
                                   Visibility="Collapsed"/>
                        <Button x:Name="BtnRegisterBgTask"
                                Content="Enable auto sync"
                                Height="36" FontSize="12"
                                Click="BtnRegisterBgTask_Click"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- PROGRESS -->
            <StackPanel x:Name="PanelProgress"
                        Visibility="Collapsed" Margin="0,16,0,0">
                <ProgressBar x:Name="ProgressBar"
                             IsIndeterminate="True"
                             Height="4" Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtProgress"
                           FontSize="13" TextWrapping="Wrap"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>

            <!-- SUCCESS -->
            <Border x:Name="BannerSuccess"
                    Background="#E8F5E9" Padding="14,10"
                    Visibility="Collapsed" Margin="0,12,0,0">
                <TextBlock x:Name="TxtSuccess"
                           FontSize="13" Foreground="#1B5E20"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- ERROR -->
            <Border x:Name="BannerError"
                    Background="#FFEBEE" Padding="14,10"
                    Visibility="Collapsed" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Error"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#B71C1C" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtError"
                               FontSize="12" Foreground="#7F0000"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- LAST SYNC -->
            <TextBlock x:Name="TxtLastSync"
                       FontSize="11"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Right"
                       Margin="0,8,0,0"
                       Visibility="Collapsed"/>

        </StackPanel>
    </ScrollViewer>
</Page>
